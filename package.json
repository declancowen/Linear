{
  "name": "linear",
  "version": "0.0.1",
  "main": "electron/main.cjs",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "pnpm web:dev",
    "web:dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "convex:codegen": "convex codegen",
    "convex:deploy": "convex deploy",
    "partykit:deploy:dev": "partykit deploy --name linear-collaboration-dev",
    "partykit:deploy:prod": "partykit deploy --name linear-collaboration-prod",
    "partykit:tail:dev": "partykit tail --name linear-collaboration-dev",
    "partykit:tail:prod": "partykit tail --name linear-collaboration-prod",
    "bootstrap:workspace": "node --env-file=.env.local scripts/bootstrap-app-workspace.mjs",
    "maintenance:backfill-lookups": "node --env-file=.env.local scripts/backfill-lookup-fields.mjs",
    "maintenance:backfill-work-item-keys": "node --env-file=.env.local scripts/backfill-work-item-keys.mjs",
    "maintenance:backfill-workspace-memberships": "node --env-file=.env.local scripts/backfill-workspace-memberships.mjs",
    "notifications:send-digests": "node --env-file=.env.local scripts/send-notification-digests.mjs",
    "emails:send-jobs": "node --env-file=.env.local scripts/send-email-jobs.mjs",
    "sync:workos:workspaces": "node --env-file=.env.local scripts/sync-workspace-organizations.mjs",
    "icons:generate": "node scripts/generate-icons.mjs",
    "desktop:dev": "concurrently -k \"cross-env APP_URL=http://localhost:3000 NEXT_PUBLIC_APP_URL=http://localhost:3000 TEAMS_URL=http://localhost:3000 NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback next dev --turbopack --hostname localhost --port 3000\" \"cross-env NODE_ENV=development NEXT_DEV_SERVER_URL=http://localhost:3000 node --env-file=.env.local scripts/run-electron.cjs\"",
    "desktop:start": "cross-env NODE_ENV=production ELECTRON_LOCAL_SERVER=1 node --env-file=.env.local scripts/run-electron.cjs",
    "desktop:package:mac": "pnpm icons:generate && node scripts/package-electron-mac.mjs",
    "desktop:smoke": "node scripts/desktop-smoke.mjs",
    "lint": "eslint app components convex electron hooks lib scripts test tests eslint.config.mjs next.config.mjs postcss.config.mjs proxy.ts vitest.config.ts --max-warnings 0",
    "test": "vitest run",
    "test:coverage": "vitest run --testTimeout 15000 --coverage --coverage.provider istanbul --coverage.reporter json",
    "test:watch": "vitest",
    "audit:deps": "pnpm audit --audit-level high",
    "fallow:dead-code": "fallow dead-code --fail-on-issues",
    "fallow:health": "fallow health --production --max-crap 1000000 --format json | node scripts/fallow-health-zero-findings-gate.mjs",
    "fallow:dupes": "fallow dupes --ignore-imports --format json | node scripts/fallow-dupes-budget-gate.mjs",
    "fallow:gate": "pnpm fallow:dead-code && pnpm fallow:health && pnpm fallow:dupes",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm desktop:smoke",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "@tiptap/core": "3.22.4",
    "@tiptap/extension-character-count": "^3.22.4",
    "@tiptap/extension-collaboration": "3.22.4",
    "@tiptap/extension-file-handler": "^3.22.4",
    "@tiptap/extension-highlight": "^3.22.4",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-mention": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/extension-table": "^3.22.4",
    "@tiptap/extension-task-item": "^3.22.4",
    "@tiptap/extension-task-list": "^3.22.4",
    "@tiptap/extension-text-align": "^3.22.4",
    "@tiptap/extension-typography": "^3.22.4",
    "@tiptap/extension-underline": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@tiptap/y-tiptap": "3.0.2",
    "@workos-inc/authkit-nextjs": "^3.0.0",
    "@workos-inc/node": "^8.12.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.35.1",
    "date-fns": "^4.1.0",
    "emoji-picker-react": "^4.18.0",
    "linkedom": "^0.18.12",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.10.0",
    "sanitize-html": "^2.17.3",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "y-partykit": "^0.0.33",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@vitest/coverage-istanbul": "4.1.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "fallow": "2.58.0",
    "jsdom": "^29.0.2",
    "msw": "^2.13.3",
    "partykit": "^0.0.115",
    "png-to-ico": "^3.0.1",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "miniflare>undici": "6.24.0",
      "plist>@xmldom/xmldom": "0.8.13"
    }
  }
}
