{
  "name": "linear",
  "version": "0.0.1",
  "main": "electron/main.mjs",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "pnpm web:dev",
    "web:dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "convex:codegen": "convex codegen",
    "convex:deploy": "convex deploy",
    "bootstrap:workspace": "node --env-file=.env.local scripts/bootstrap-app-workspace.mjs",
    "notifications:send-digests": "node --env-file=.env.local scripts/send-notification-digests.mjs",
    "sync:workos:workspaces": "node --env-file=.env.local scripts/sync-workspace-organizations.mjs",
    "desktop:dev": "concurrently -k \"pnpm web:dev\" \"cross-env NEXT_DEV_SERVER_URL=http://127.0.0.1:3000 electron electron/main.mjs\"",
    "desktop:start": "cross-env NODE_ENV=production electron electron/main.mjs",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "@tiptap/extension-character-count": "^3.22.3",
    "@tiptap/extension-file-handler": "^3.22.3",
    "@tiptap/extension-highlight": "^3.22.3",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-mention": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/extension-table": "^3.22.3",
    "@tiptap/extension-task-item": "^3.22.3",
    "@tiptap/extension-task-list": "^3.22.3",
    "@tiptap/extension-text-align": "^3.22.3",
    "@tiptap/extension-typography": "^3.22.3",
    "@tiptap/extension-underline": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@workos-inc/authkit-nextjs": "^3.0.0",
    "@workos-inc/node": "^8.12.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.35.1",
    "date-fns": "^4.1.0",
    "emoji-picker-react": "^4.18.0",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "3.8.0",
    "resend": "^6.10.0",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "jsdom": "^29.0.2",
    "msw": "^2.13.3",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
