CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_SERVER_TOKEN=replace-with-a-long-random-shared-secret
# Optional dual-environment wipe script configuration.
CONVEX_URL_DEVELOPMENT=https://your-dev-deployment.convex.cloud
CONVEX_URL_PRODUCTION=https://your-prod-deployment.convex.cloud
CONVEX_SERVER_TOKEN_DEVELOPMENT=replace-with-your-development-server-token
CONVEX_SERVER_TOKEN_PRODUCTION=replace-with-your-production-server-token
CONVEX_DEPLOY_KEY=dev:your-deployment|...
WORKOS_CLIENT_ID=client_...
WORKOS_API_KEY=sk_...
WORKOS_COOKIE_PASSWORD=replace-with-a-32-char-secret
# Use localhost for local dev, and your shared apex domain in production.
WORKOS_COOKIE_DOMAIN=localhost
# For a sandbox WorkOS client, localhost is fine.
# For a production WorkOS client, this must be a public HTTPS callback URL.
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
TEAMS_URL=http://localhost:3000
# Electron-only override for local desktop development.
NEXT_DEV_SERVER_URL=http://127.0.0.1:3000
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@example.com
HMS_ACCESS_KEY=69c845...
HMS_SECRET=replace-with-your-100ms-secret
HMS_TEMPLATE_ID=69c846...
HMS_TEMPLATE_SUBDOMAIN=declan-videoconf-2119
# Optional script flag for previewing notification digests without sending them.
DRY_RUN=0
