# Runtime environment values used by the app and scripts.
# Keep only the exact env names the runtime reads directly in the active block below.
# Reference profiles are comments only; they are not read by runtime.
# Current active profile: local app URLs + current local provider values.

# Active Runtime Values

# Convex
CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_SERVER_TOKEN=replace-with-a-long-random-shared-secret
CONVEX_DEPLOY_KEY=dev:your-deployment|...

# WorkOS
WORKOS_CLIENT_ID=client_...
WORKOS_API_KEY=sk_...
WORKOS_COOKIE_PASSWORD=replace-with-a-32-char-secret
# Server-only secret used by hosted Vercel routes to issue desktop session tokens.
DESKTOP_SESSION_SECRET=replace-with-a-long-random-desktop-session-secret
# Leave blank on localhost. Set your shared parent domain in deployed environments.
WORKOS_COOKIE_DOMAIN=
# Local auth callbacks should point at your local app origin.
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback
# Hosted WorkOS callback used by desktop browser handoff.
DESKTOP_WORKOS_REDIRECT_URI=https://teams.reciperoom.io/auth/desktop/callback
# Desktop custom URL scheme used after hosted auth completes.
DESKTOP_DEEP_LINK_SCHEME=recipe-room
# Comma-separated desktop renderer origins allowed to call hosted API routes.
# Include "null" for the packaged file:// renderer.
DESKTOP_API_ALLOWED_ORIGINS=
# Optional release-preflight evidence markers after checking provider dashboards.
DESKTOP_WORKOS_REDIRECTS_VERIFIED=0
DESKTOP_HOSTED_API_CORS_VERIFIED=0

# Vercel / App Hosting
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
TEAMS_URL=http://localhost:3000
# Leave blank for same-origin web dev. Set to the hosted Vercel origin for packaged desktop builds.
NEXT_PUBLIC_API_BASE_URL=
# Electron-only overrides for desktop development and transition builds.
NEXT_DEV_SERVER_URL=http://127.0.0.1:3000
ELECTRON_RENDERER_URL=https://teams.reciperoom.io

# PartyKit / Collaboration
# Local app development should point at the hosted dev PartyKit service.
NEXT_PUBLIC_PARTYKIT_URL=https://linear-collaboration-dev.your-subdomain.partykit.dev
COLLABORATION_TOKEN_SECRET=replace-with-a-long-random-collaboration-secret
# Bounds best-effort app-to-PartyKit refresh notifications after Convex mutations.
COLLABORATION_REFRESH_TIMEOUT_MS=1500

# Email
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@example.com
CRON_SECRET=replace-with-a-long-random-cron-secret
# Set to 1 to preview notification digests without sending them.
DRY_RUN=0

# 100ms
HMS_ACCESS_KEY=69c845...
HMS_SECRET=replace-with-your-100ms-secret
HMS_TEMPLATE_ID=69c846...
HMS_TEMPLATE_SUBDOMAIN=declan-videoconf-2119

# Reference Profiles
# Copy values from the blocks below into the active runtime block above when switching environments.

# Convex Reference Profiles
# Development and production can point at different Convex clouds.
# Development / local dev deployment
# CONVEX_URL=https://dev-deployment.convex.cloud
# NEXT_PUBLIC_CONVEX_URL=https://dev-deployment.convex.cloud
# CONVEX_SERVER_TOKEN=replace-with-your-shared-server-token
# CONVEX_DEPLOY_KEY=fill-in-dev-deploy-key-if-needed
# Production / Vercel
# CONVEX_URL=https://prod-deployment.convex.cloud
# NEXT_PUBLIC_CONVEX_URL=https://prod-deployment.convex.cloud
# CONVEX_SERVER_TOKEN=replace-with-your-shared-server-token
# CONVEX_DEPLOY_KEY=prod:your-prod-deployment|...

# WorkOS Reference Profiles
# Development / current local provider target
# WORKOS_CLIENT_ID=client_dev_...
# WORKOS_API_KEY=sk_dev_...
# WORKOS_COOKIE_PASSWORD=replace-with-your-dev-cookie-password
# DESKTOP_SESSION_SECRET=replace-with-your-dev-desktop-session-secret
# WORKOS_COOKIE_DOMAIN=
# NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback
# DESKTOP_WORKOS_REDIRECT_URI=https://your-dev-domain.com/auth/desktop/callback
# DESKTOP_DEEP_LINK_SCHEME=recipe-room
# DESKTOP_API_ALLOWED_ORIGINS=
# Production / Vercel
# WORKOS_CLIENT_ID=client_prod_...
# WORKOS_API_KEY=sk_prod_...
# WORKOS_COOKIE_PASSWORD=replace-with-your-prod-cookie-password
# DESKTOP_SESSION_SECRET=replace-with-your-prod-desktop-session-secret
# WORKOS_COOKIE_DOMAIN=your-production-domain.com
# NEXT_PUBLIC_WORKOS_REDIRECT_URI=https://your-production-domain.com/callback
# DESKTOP_WORKOS_REDIRECT_URI=https://your-production-domain.com/auth/desktop/callback
# DESKTOP_DEEP_LINK_SCHEME=recipe-room
# DESKTOP_API_ALLOWED_ORIGINS=null
# DESKTOP_WORKOS_REDIRECTS_VERIFIED=0
# DESKTOP_HOSTED_API_CORS_VERIFIED=0

# Vercel / App Hosting Reference Profiles
# Local development
# APP_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# TEAMS_URL=http://localhost:3000
# NEXT_PUBLIC_API_BASE_URL=
# NEXT_DEV_SERVER_URL=http://127.0.0.1:3000
# ELECTRON_RENDERER_URL=http://127.0.0.1:3000
# Preview / Vercel
# VERCEL_URL=https://your-preview-domain.vercel.app
# Production / Vercel
# APP_URL=https://your-production-domain.com
# NEXT_PUBLIC_APP_URL=https://your-production-domain.com
# TEAMS_URL=https://your-production-domain.com
# NEXT_PUBLIC_API_BASE_URL=https://your-production-domain.com
# ELECTRON_RENDERER_URL=https://your-production-domain.com

# WorkOS URL Reference Profiles
# Local development
# NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback
# Production / Vercel
# NEXT_PUBLIC_WORKOS_REDIRECT_URI=https://your-production-domain.com/callback

# PartyKit Reference Profiles
# Development / hosted Cloudflare PartyKit service
# NEXT_PUBLIC_PARTYKIT_URL=https://linear-collaboration-dev.your-subdomain.partykit.dev
# COLLABORATION_TOKEN_SECRET=replace-with-your-dev-collaboration-secret
# Production / hosted Cloudflare PartyKit service
# NEXT_PUBLIC_PARTYKIT_URL=https://linear-collaboration-prod.your-subdomain.partykit.dev
# COLLABORATION_TOKEN_SECRET=replace-with-your-prod-collaboration-secret

# Email Reference Profiles
# Development / current local provider target
# RESEND_API_KEY=re_dev_...
# RESEND_FROM_EMAIL=dev@example.com
# CRON_SECRET=replace-with-your-dev-cron-secret
# Production / Vercel
# RESEND_API_KEY=re_prod_...
# RESEND_FROM_EMAIL=noreply@example.com
# CRON_SECRET=replace-with-your-prod-cron-secret

# 100ms Reference Profiles
# Development / current local provider target
# HMS_ACCESS_KEY=replace-with-your-dev-access-key
# HMS_SECRET=replace-with-your-dev-secret
# HMS_TEMPLATE_ID=replace-with-your-dev-template-id
# HMS_TEMPLATE_SUBDOMAIN=your-dev-subdomain
# Production / Vercel
# HMS_ACCESS_KEY=replace-with-your-prod-access-key
# HMS_SECRET=replace-with-your-prod-secret
# HMS_TEMPLATE_ID=replace-with-your-prod-template-id
# HMS_TEMPLATE_SUBDOMAIN=your-prod-subdomain
